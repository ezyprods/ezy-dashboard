# ─── Better Auth ─────────────────────────────────────────────────────────────
# IMPORTANTE: En Vercel, establece BETTER_AUTH_URL al dominio de producción:
#   BETTER_AUTH_URL=https://ezyprods-dashboard.vercel.app
# En desarrollo local déjala como localhost:3000
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Esta variable PÚBLICA permite que el cliente de Next.js sepa la URL del servidor.
# En Vercel, pon el mismo valor que BETTER_AUTH_URL:
#   NEXT_PUBLIC_BETTER_AUTH_URL=https://ezyprods-dashboard.vercel.app
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Google APIs (Drive + Calendar) ──────────────────────────────────────────
# Refresh token permanente obtenido con offline access + prompt=consent
GOOGLE_REFRESH_TOKEN=

# ─── Google Drive ─────────────────────────────────────────────────────────────
DRIVE_ROOT_FOLDER_ID=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=EZY Studio
NEXT_PUBLIC_PRODUCER_NAME=EZY
